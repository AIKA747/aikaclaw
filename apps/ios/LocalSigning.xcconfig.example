// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

AIKACLAW_CODE_SIGN_STYLE = Automatic
AIKACLAW_DEVELOPMENT_TEAM = YOUR_TEAM_ID

AIKACLAW_APP_BUNDLE_ID = ai.aikaclaw.client
AIKACLAW_SHARE_BUNDLE_ID = ai.aikaclaw.client.share
AIKACLAW_ACTIVITY_WIDGET_BUNDLE_ID = ai.aikaclaw.client.activitywidget
AIKACLAW_WATCH_APP_BUNDLE_ID = ai.aikaclaw.client.watchkitapp
AIKACLAW_WATCH_EXTENSION_BUNDLE_ID = ai.aikaclaw.client.watchkitapp.extension

// Leave empty with automatic signing.
AIKACLAW_APP_PROFILE =
AIKACLAW_SHARE_PROFILE =
