# AikaClaw gateway — Podman Quadlet (rootless)
# Installed by scripts/podman/setup.sh into aikaclaw's ~/.config/containers/systemd/
# {{AIKACLAW_HOME}} is replaced at install time.

[Unit]
Description=AikaClaw gateway (rootless Podman)

[Container]
Image=aikaclaw:local
ContainerName=aikaclaw
UserNS=keep-id
# Keep container UID/GID aligned with the invoking user so mounted config is readable.
User=%U:%G
Volume={{AIKACLAW_HOME}}/.aikaclaw:/home/node/.aikaclaw:Z
EnvironmentFile={{AIKACLAW_HOME}}/.aikaclaw/.env
Environment=HOME=/home/node
Environment=TERM=xterm-256color
PublishPort=18789:18789
PublishPort=18790:18790
Pull=never
Exec=node dist/index.js gateway --bind lan --port 18789

[Service]
TimeoutStartSec=300
Restart=on-failure

[Install]
WantedBy=default.target
